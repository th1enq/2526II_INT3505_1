#%RAML 0.8
title: Product Management API
version: 1.0.0
baseUri: http://localhost
mediaType: application/json

schemas:
  - ProductInput: |
      {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "price": { "type": "number" },
          "description": { "type": "string" }
        },
        "required": ["name", "price"]
      }

  - Product: |
      {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "price": { "type": "number" },
          "description": { "type": "string" }
        },
        "required": ["id", "name", "price"]
      }

/api/products:
  get:
    description: Get all products
    responses:
      200:
        body:
          application/json:
            schema: Product[]
            example: |
              [
                {
                  "id": 1,
                  "name": "Awesome Product",
                  "price": 99.99
                }
              ]

  post:
    description: Create a new product
    body:
      application/json:
        schema: ProductInput
        example: |
          {
            "name": "Awesome Product",
            "price": 99.99
          }
    responses:
      201:
        body:
          application/json:
            schema: Product
            example: |
              {
                "id": 1,
                "name": "Awesome Product",
                "price": 99.99
              }

/api/products/{product_id}:
  uriParameters:
    product_id:
      type: integer
      required: true

  get:
    description: Get a product by ID
    responses:
      200:
        body:
          application/json:
            schema: Product

  put:
    description: Update a product
    body:
      application/json:
        schema: ProductInput
    responses:
      200:
        body:
          application/json:
            schema: Product

  delete:
    description: Delete a product
    responses:
      200:
        body:
          application/json:
            example: |
              { "message": "Deleted successfully" }
