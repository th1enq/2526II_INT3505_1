          "type": "string",
          "description": "Product name"
        },
        "price": {
          "type": "number",
          "description": "Product price"
        },
        "description": {
          "type": "string",
          "description": "Product description"
        }
      },
      "type": "object"
    }
  },
  "responses": {
    "ParseError": {
      "description": "When a mask can't be parsed"
    },
    "MaskError": {
      "description": "When any error occurs on mask"
