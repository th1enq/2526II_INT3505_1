      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Sum response is correct', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.eql({ count: 3, sum: 6.5 });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Sum Numbers Empty List",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
